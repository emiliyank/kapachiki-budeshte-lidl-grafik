# -----------------------------------------------
# ЛОКАЛНА РАЗРАБОТКА
# Копирайте този файл като .env.local и попълнете стойностите
# -----------------------------------------------

# База данни — локална (Docker/PostgreSQL)
DATABASE_URL=""
SHADOW_DATABASE_URL=""

# NextAuth
AUTH_SECRET=""           # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Resend (за имейл напомняния) — може да оставите празно при локална разработка
RESEND_API_KEY=""

# Vercel Cron защита — произволен таен низ
CRON_SECRET=""

# Парола за първия Admin акаунт (използва се само при npx prisma db seed)
ADMIN_SEED_PASSWORD=""
